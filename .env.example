# Telegram — get from @BotFather and @userinfobot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_OWNER_ID=123456789

# Claude Agent SDK — run `claude setup-token` to get this
CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token

# Todoist — Settings > Integrations > Developer
TODOIST_API_TOKEN=your-todoist-api-token

# Perplexity (optional) — web search for the agent
PERPLEXITY_API_KEY=your-perplexity-api-key

# Proton Pass (optional) — for browser automation credential retrieval
# Log in manually once: docker exec -it nudge-bot pass-cli login --interactive your@proton.me
PROTON_PASS_USERNAME=your@proton.me
